# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose your LLM backend. Default is anthropic.
# Valid values: anthropic | openai
LLM_PROVIDER=anthropic

# Model to use. If unset, the provider default is used.
# Anthropic default : claude-sonnet-4-6
# OpenAI default    : gpt-4o
# LLM_MODEL=claude-sonnet-4-6

# Comma-separated frontend origins allowed to call the backend.
# CORS_ALLOW_ORIGINS=http://localhost:3001,http://localhost:5173,http://localhost:3000

# Maximum accepted request body size in bytes.
# MAX_REQUEST_BYTES=262144

# Maximum time to wait for a single LLM call.
# LLM_TIMEOUT_SECONDS=60

# ── Anthropic (LLM_PROVIDER=anthropic) ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── OpenAI or compatible (LLM_PROVIDER=openai) ───────────────────────────────
# Compatible providers: OpenAI, Groq, Together.ai, Ollama, Azure OpenAI, LM Studio, etc.
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1   # omit for official OpenAI

# Frontend API base URL. Leave unset in local dev to use the Vite proxy.
# VITE_API_URL=http://localhost:8000
